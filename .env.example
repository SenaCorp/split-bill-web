# OpenAI key used by the server-side OCR proxy. Keep this secret on the API server.
OPENAI_API_KEY=

# Supabase settings used by the Node/Express API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MinIO / S3-compatible storage for payment proof uploads.
MINIO_ENDPOINT=
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=split-bill-proofs

# Public URL where users open the app.
# Root domain example: https://sena.my.id
# Subpath example: https://sena.my.id/split-bill
APP_BASE_URL=http://localhost:5173

# Path prefix where the built frontend is served.
# Use / when deploying at the domain root, for example https://sena.my.id/.
# Use /split-bill when deploying below https://sena.my.id/split-bill.
# This prevents Vite from emitting asset URLs that point at the wrong path and cause 404s.
APP_BASE_PATH=/
VITE_APP_BASE_PATH=/

# API origin for local development or split frontend/API hosting.
API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=

# Optional CORS override. Leave empty to allow default Express CORS behavior.
CORS_ORIGIN=
